const express = require('express');
const fs = require('fs');
const cors = require('cors');
const app = express();
const PORT = process.env.PORT || 3000;

app.use(cors());
app.use(express.json());

const UPDATES_FILE = './updates.json';
if(!fs.existsSync(UPDATES_FILE)) fs.writeFileSync(UPDATES_FILE,'[]');

app.get('/updates', (req,res)=>{
  const data = JSON.parse(fs.readFileSync(UPDATES_FILE));
  res.json(data);
});

app.post('/updates', (req,res)=>{
  const {text} = req.body;
  if(!text) return res.status(400).json({error:"Brak tekstu"});
  const updates = JSON.parse(fs.readFileSync(UPDATES_FILE));
  updates.push({text, approved:false});
  fs.writeFileSync(UPDATES_FILE, JSON.stringify(updates,null,2));
  res.json({success:true});
});

app.post('/updates/approve/:index', (req,res)=>{
  const idx = req.params.index;
  const updates = JSON.parse(fs.readFileSync(UPDATES_FILE));
  if(updates[idx]) updates[idx].approved = true;
  fs.writeFileSync(UPDATES_FILE, JSON.stringify(updates,null,2));
  res.json({success:true});
});

app.delete('/updates/:index', (req,res)=>{
  const idx = req.params.index;
  let updates = JSON.parse(fs.readFileSync(UPDATES_FILE));
  updates.splice(idx,1);
  fs.writeFileSync(UPDATES_FILE, JSON.stringify(updates,null,2));
  res.json({success:true});
});

app.listen(PORT,()=>console.log(`Server on port ${PORT}`));
